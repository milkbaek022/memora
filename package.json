{
  "name": "memora",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/api",
    "apps/extension",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "pack:extension": "npm run pack:store --workspace @memora/extension",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --pretty false",
    "test:e2e": "playwright test e2e/extension-smoke.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
